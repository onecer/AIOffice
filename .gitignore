# .NET build output
bin/
obj/
artifacts/

# ...but the npm package's bin shim is a real source file, not build output —
# the blanket bin/ rule above would otherwise drop it and ship a broken package.
# Track ONLY the JS shim; the downloaded ~38MB platform binary that postinstall
# places next to it (npm/bin/aioffice[.exe]) must never be committed.
!npm/bin/
npm/bin/*
!npm/bin/aioffice.js

# User-specific / IDE
*.user
*.suo
.vs/
.idea/
*.swp

# Node (the npm/ package)
node_modules/
*.tgz

# NuGet
*.nupkg
packages/

# Secrets / local env (defensive — none are used, but never let one slip in)
.env
.env.*
*.pem
*.key

# Snapshot ring scratch (the real ring lives in ~/.aioffice/snapshots/, but never
# track a stray .snap if a test or run writes one into the tree)
*.snap

# Test results
TestResults/
*.trx
coverage/
*.coverage

# OS noise
.DS_Store

# test scratch space (fixtures/manual-check/ stays tracked)
fixtures/tmp/

# logs
*.log
.omc/logs/

# publish output — the built single-file binaries under dist/<rid>/ are publish
# artifacts (ignored), but the distribution SOURCE in dist/ (install scripts, the
# Homebrew formula, README) is tracked: install.sh/install.ps1 are served from
# raw.githubusercontent.com/.../main/dist/, and the formula is copied into the tap.
dist/osx-arm64/
dist/osx-x64/
dist/win-x64/
dist/win-arm64/
dist/linux-x64/
dist/linux-arm64/
release-v0.4.0/
